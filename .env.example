# Graph Analytics AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================================================
# ArangoDB Connection (Required for all deployments)
# ============================================================================
ARANGO_ENDPOINT=https://your-cluster.arangodb.cloud:8529
ARANGO_USER=root
ARANGO_PASSWORD=your-password-here
ARANGO_DATABASE=your-database-name

# Optional: SSL verification (default: true)
# Set to false only for development/testing with self-signed certificates
ARANGO_VERIFY_SSL=true

# Optional: Connection timeout in seconds (default: 30)
ARANGO_TIMEOUT=30

# ============================================================================
# GAE Deployment Mode
# ============================================================================
# Set to either 'amp' or 'self_managed'
GAE_DEPLOYMENT_MODE=amp

# ============================================================================
# AMP (Arango Managed Platform) Configuration
# ============================================================================
# Required when GAE_DEPLOYMENT_MODE=amp
ARANGO_GRAPH_API_KEY_ID=your-api-key-id
ARANGO_GRAPH_API_KEY_SECRET=your-api-key-secret

# Optional: Pre-generated token (if you have one)
# ARANGO_GRAPH_TOKEN=your-token-here

# Optional: GAE port (default: 8829)
ARANGO_GAE_PORT=8829

# ============================================================================
# Self-Managed Configuration
# ============================================================================
# When GAE_DEPLOYMENT_MODE=self_managed, no additional GAE credentials needed
# The library will use JWT tokens from ArangoDB connection

# ============================================================================
# Product API — Agentic Workflow Supervisor (FR-31a Phase 1)
# ============================================================================
# When set to "1" / "true", the FastAPI product API spins up an
# AgenticRunSupervisor on startup so POST /api/runs/{id}/start in
# AGENTIC mode actually invokes the AgenticWorkflowRunner in a
# background thread (and POST /api/runs/{id}/cancel can stop it
# cooperatively). The supervisor also sweeps orphan RUNNING rows
# on startup so an API restart leaves a clean state.
#
# Leave unset for the default off behaviour (agentic runs queue
# but never execute) — useful when you only want the visualizer
# UX surface and not real LLM traffic.
#AGA_ENABLE_AGENTIC_SUPERVISOR=1

# Optional override for permitted CORS origins (comma-separated).
# Defaults to http://localhost:3000 + http://127.0.0.1:3000.
#AGA_PRODUCT_CORS_ORIGINS=http://localhost:3000,https://aga.example.com

# ============================================================================
# Example Configurations
# ============================================================================

# Example: AMP Deployment
# ARANGO_ENDPOINT=https://mycluster.arangodb.cloud:8529
# ARANGO_USER=root
# ARANGO_PASSWORD=secure-password
# ARANGO_DATABASE=mydb
# GAE_DEPLOYMENT_MODE=amp
# ARANGO_GRAPH_API_KEY_ID=abc123
# ARANGO_GRAPH_API_KEY_SECRET=xyz789

# Example: Self-Managed Deployment
# ARANGO_ENDPOINT=https://my-server.local:8529
# ARANGO_USER=root
# ARANGO_PASSWORD=secure-password
# ARANGO_DATABASE=mydb
# ARANGO_VERIFY_SSL=false
# GAE_DEPLOYMENT_MODE=self_managed
